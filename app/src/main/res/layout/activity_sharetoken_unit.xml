<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/light"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Sharetoken_unit">

    <LinearLayout
        android:id="@+id/main2"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="28dp">

            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_share"
                app:tint="#6C63FF"
                android:background="@drawable/circle_amber"
                android:padding="14dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share Token Unit"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transfer units to another meter"
                android:textSize="13sp"
                android:textColor="#9CA3AF"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:indeterminate="true"
            android:indeterminateTint="#6C63FF"
            android:visibility="gone"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOURCE METER"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#6C63FF"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"/>

        <!-- Source Meter Number -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Meter number"
            app:startIconDrawable="@drawable/baseline_message_24"
            app:boxStrokeColor="#6C63FF"
            app:hintTextColor="#6C63FF"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/mtrnum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Token Unit to share -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Token unit to share"
            app:startIconDrawable="@drawable/baseline_access_time_filled_24"
            app:boxStrokeColor="#6C63FF"
            app:hintTextColor="#6C63FF"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tknunit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Divider with arrow -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E5E7EB"/>
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/baseline_arrow_downward_24"
                android:background="@drawable/circle_amber"
                android:padding="8dp"
                android:layout_marginHorizontal="12dp"
                app:tint="#6C63FF"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E5E7EB"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESTINATION METER"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#F59E0B"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"/>

        <!-- Delivery Meter Number -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Delivery meter number"
            app:startIconDrawable="@drawable/baseline_send_24"
            app:boxStrokeColor="#F59E0B"
            app:hintTextColor="#F59E0B"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/delivery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Token Balance (read-only display) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Token balance unit"
            app:startIconDrawable="@drawable/baseline_account_balance_wallet_24"
            app:boxStrokeColor="#F59E0B"
            app:hintTextColor="#F59E0B"
            android:layout_marginBottom="32dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/bala"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:background="@null"
                android:textColor="#9CA3AF"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnshare"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Share Token"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#6C63FF"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_share"
            app:iconGravity="textStart"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:id="@+id/btnbac"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Back"
            android:textSize="15sp"
            android:textColor="#6C63FF"
            app:strokeColor="#6C63FF"
            app:strokeWidth="1.5dp"
            app:cornerRadius="14dp"
            app:backgroundTint="@android:color/transparent"/>

    </LinearLayout>
</ScrollView>