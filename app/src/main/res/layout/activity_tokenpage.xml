<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Tokenpage">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#1E3A5F"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

    <TextView
        android:layout_marginTop="7dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.15"
        android:textSize="20sp"
        android:textColor="@color/green"
        android:text="DERRICK POWER"/>

        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:background="#F59E0B"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#161B22"
                app:strokeColor="#30363D"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENTER DETAILS"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="14dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="METER NUMBER"
                        android:textColor="#F59E0B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>



                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="14dp"
                        app:startIconDrawable="@drawable/meter"
                        app:startIconTint="#F59E0B"
                        app:boxStrokeColor="#F59E0B"
                        app:hintTextColor="#F59E0B"
                        app:boxBackgroundColor="#0B1120"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/num"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter meter number"
                            android:textColor="#F1F5F9"
                            android:textSize="14sp"
                            android:inputType="number"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMOUNT (KSH)"
                        android:textColor="#34D399"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <!-- Amount Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:startIconDrawable="@drawable/baseline_attach_money_24"
                        app:startIconTint="#34D399"
                        app:boxStrokeColor="#34D399"
                        app:hintTextColor="#34D399"
                        app:boxBackgroundColor="#0B1120"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/amount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter amount"
                            android:textColor="#F1F5F9"
                            android:textSize="14sp"
                            android:inputType="numberDecimal"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <Button
                android:id="@+id/btnk"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="⚡  Generate Token"
                android:textColor="#0B1120"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn__amber"
                android:layout_marginBottom="14dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#161B22"
                app:strokeColor="#30363D"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RESULTS"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="14dp"/>

                    <!-- Cash -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cash Amount"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/csh"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="12dp"
                        android:textColor="#F59E0B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:background="@drawable/result_field"
                        android:editable="false"
                        android:focusable="false"/>

                    <!-- Token -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Token Number"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/tkn"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="12dp"
                        android:textColor="#34D399"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:paddingStart="14dp"
                        android:background="@drawable/result_field"
                        android:editable="false"
                        android:focusable="false"/>

                    <!-- Meter -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Meter Number"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/mtr"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:textColor="#818CF8"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:background="@drawable/result_field"
                        android:focusable="false"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="14dp">

                <Button
                    android:id="@+id/btncl"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="🗑  Clear"
                    android:textColor="#E11D48"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_red"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnbac"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="← Back"
                    android:textColor="#34D399"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_green"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <!-- Generate Message Button -->
            <Button
                android:id="@+id/btnmess"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✉  Generate Message"
                android:textColor="#818CF8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_indigo"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>