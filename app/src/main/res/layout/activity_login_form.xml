<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#0F172A"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Login_form">

    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="48dp">
        <View
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/logo_send"/>
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_send"
            app:tint="#FFFFFF" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Log In"
        android:textColor="#F8FAFC"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="log in form"
        android:textColor="#64748B"
        android:textSize="13sp"
        android:layout_marginTop="4dp"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/logo_send"
        android:padding="24dp"
        android:layout_marginTop="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USERNAME"
            android:textColor="#818CF8"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"/>


    <EditText
        android:id="@+id/logname"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:drawableStart="@drawable/round_person_24"
        android:layout_marginTop="20dp"
        android:hint="Enter name"
        android:textColorHint="#50818CF8"
        android:textColor="#F1F5F9"
        android:textSize="14sp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/log_sen"
        android:inputType="textPersonName"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:textColor="@color/green"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:layout_marginTop="18dp"/>

    <EditText
        android:id="@+id/logpassord"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="30dp"
        android:hint="Enter password"
        android:drawableStart="@drawable/baseline_lock_24"
        android:textColor="#F1F5F9"
        android:textSize="14sp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/inpu_green"
        android:inputType="textPassword"/>

    <Button
        android:id="@+id/btnlog"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="log in"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/input_indigo"
        android:layout_marginTop="24dp"/>
    </LinearLayout>

        <TextView
            android:id="@+id/crtaccoun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New here? Create an account"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:layout_marginTop="20dp"/>

</LinearLayout>