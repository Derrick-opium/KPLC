<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light"
    android:padding="24dp"
    android:gravity="center_horizontal"
    tools:context=".Deposit_token">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/baseline_bolt_24"
        android:background="@drawable/circle_gradient"
        android:padding="18dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deposit Token"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginTop="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your meter details below"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="36dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Meter Number Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Meter Number"
                app:startIconDrawable="@drawable/baseline_message_24"
                app:boxStrokeColor="#1A73E8"
                app:hintTextColor="#1A73E8">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/depositmtrnum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="#1A1A2E"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Token Unit Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Token Units"
                app:startIconDrawable="@drawable/baseline_access_time_filled_24"
                app:boxStrokeColor="#1A73E8"
                app:hintTextColor="#1A73E8">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tknunit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="#1A1A2E"/>

            </com.google.android.material.textfield.TextInputLayout>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btndepo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="Deposit Unit"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1A73E8"
                app:cornerRadius="12dp"
                app:icon="@drawable/baseline_bolt_24"
                app:iconGravity="textStart"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnbac"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Back"
                android:textSize="16sp"
                android:textColor="#1A73E8"
                app:backgroundTint="@android:color/transparent"
                app:strokeColor="#1A73E8"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>


</LinearLayout>